{
  "name": "nexomente",
  "version": "1.0.0",
  "description": "NexoMente - Segundo cérebro offline com LLM local",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "lint": "eslint app/src/ --max-warnings 999"
  },
  "lint-staged": {
    "app/src/**/*.{js,jsx}": [
      "eslint --fix --max-warnings 999"
    ]
  },
  "author": "Bruno",
  "license": "MIT",
  "dependencies": {
    "@sentry/react": "^10.50.0",
    "@tiptap/extension-blockquote": "^2.2.0",
    "@tiptap/extension-code-block": "^2.2.0",
    "@tiptap/extension-highlight": "^2.2.0",
    "@tiptap/extension-link": "^2.2.0",
    "@tiptap/extension-mathematics": "^3.22.4",
    "@tiptap/extension-placeholder": "^2.2.0",
    "@tiptap/extension-task-item": "^2.2.0",
    "@tiptap/extension-task-list": "^2.2.0",
    "@tiptap/extension-underline": "^2.2.0",
    "@tiptap/react": "^2.2.0",
    "@tiptap/starter-kit": "^2.2.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.9.0",
    "canvas-confetti": "^1.9.4",
    "chokidar": "^3.6.0",
    "cytoscape": "^3.28.0",
    "date-fns": "^3.3.0",
    "framer-motion": "^11.0.0",
    "katex": "^0.16.45",
    "lucide-react": "^0.330.0",
    "node-llama-cpp": "^3.18.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.0",
    "sql.js": "^1.10.0",
    "vosk-browser": "^0.0.8",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^9.3.0",
    "@testing-library/react": "^14.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.6",
    "postcss": "^8.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.1.0",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.bruno.nexomente",
    "productName": "NexoMente",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/models/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/models",
        "to": "models",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NexoMente"
    }
  }
}
