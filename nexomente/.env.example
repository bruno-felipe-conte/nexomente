# NexoMente — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com valores reais.
#
# Como obter:
#   LM Studio: http://localhost:1234 (padrão, sem chave)
#   Ollama: http://localhost:11434 (padrão, sem chave)

# ─── LLM Local ────────────────────────────────────────────────
# URL base da API de LLM (LM Studio, Ollama, Jan, etc.)
VITE_LLM_BASE_URL=http://localhost:1234/v1

# Modelo padrão a usar (ex: "llama-3-8b-instruct", "mistral-7b")
VITE_LLM_DEFAULT_MODEL=

# ─── Monitoramento (Fase 8 — opcional) ───────────────────────
# DSN do Sentry para rastrear erros em produção
# Obtenha em: https://sentry.io
VITE_SENTRY_DSN=

# ─── Ambiente ─────────────────────────────────────────────────
# Valores possíveis: development | production | test
VITE_APP_ENV=development
